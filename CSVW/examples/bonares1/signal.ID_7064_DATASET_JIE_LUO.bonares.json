    "resourceInfo": {
        "title": "Gross N2O emission and uptake in cropland agroforestry and monoculture systems",
        "title_de": "Brutto-N2O-Emission und -Aufnahme in Agroforstwirtschaft und Monokultur",
        "alternateTitle": "",
        "issuedDate": "2021-09-14",
        "creationDate": "2021-09-14",
        "revisionDate": "2021-09-14",
